#!/usr/bin/env bash
# greg — multi-agent Claude Code manager

set -euo pipefail

GREG_HOME="${HOME}/.greg"
SESSIONS_FILE="${GREG_HOME}/sessions.json"
HISTORY_FILE="${GREG_HOME}/history.json"
TASKS_FILE="${GREG_HOME}/tasks.json"
MULTI_TASKS_DIR="${GREG_HOME}/multi-tasks"
SKILLS_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../skills"
DEFAULT_DIR="${GREG_VAULT:-$HOME}"
CLAUDE_FLAGS="--dangerously-skip-permissions"
GREG_BIN="$(realpath "${BASH_SOURCE[0]}")"

# ── Init ──────────────────────────────────────────────────────────────────────

_init() {
  mkdir -p "${GREG_HOME}" "${MULTI_TASKS_DIR}"
  [[ -f "${SESSIONS_FILE}" ]] || echo '[]' > "${SESSIONS_FILE}"
  [[ -f "${HISTORY_FILE}" ]]  || echo '[]' > "${HISTORY_FILE}"
  [[ -f "${TASKS_FILE}" ]]    || echo '[]' > "${TASKS_FILE}"
}

# ── Multi-task helpers ────────────────────────────────────────────────────────

_resolve_skill() {
  local skill_file="$1"
  local task_id="$2"
  local agent_id="$3"
  local agent_role="$4"
  local task_goal="$5"
  local workspace="$6"
  local session_id="${7:-}"

  # Read mailbox skill and inline it (resolve {{> greg-mailbox}})
  local mailbox_content
  mailbox_content=$(cat "${SKILLS_DIR}/agents/mailbox.md")

  local content
  content=$(cat "${skill_file}")

  # Replace partial include
  content="${content//'{{> greg-mailbox}}'/$mailbox_content}"

  # Replace variables
  content="${content//'{{TASK_ID}}'/$task_id}"
  content="${content//'{{AGENT_ID}}'/$agent_id}"
  content="${content//'{{AGENT_ROLE}}'/$agent_role}"
  content="${content//'{{TASK_GOAL}}'/$task_goal}"
  content="${content//'{{WORKSPACE}}'/$workspace}"
  content="${content//'{{SESSION_ID}}'/$session_id}"
  content="${content//'{{GREG_BIN}}'/$GREG_BIN}"

  echo "$content"
}

_spawn_agent() {
  local session_id="$1"
  local name="$2"
  local workspace="$3"
  local prompt="$4"
  local model_id="${5:-}"

  local entry
  entry=$(jq -n \
    --arg id      "$session_id" \
    --arg name    "$name" \
    --arg dir     "$workspace" \
    --arg started "$(_now)" \
    '{id:$id, name:$name, dir:$dir, started:$started, status:"active"}')
  local tmp; tmp=$(mktemp)
  jq ". += [$entry]" "${SESSIONS_FILE}" > "$tmp" && mv "$tmp" "${SESSIONS_FILE}"

  # Generate a unique capture marker — prepended to the prompt so it appears only in
  # this agent's .jsonl (not in manifest.json or any shared file)
  local capture_id; capture_id="gc-$(uuidgen | tr '[:upper:]' '[:lower:]')"

  # Write prompt to a temp file to avoid shell escaping issues
  local prompt_file; prompt_file=$(mktemp /tmp/greg-prompt-XXXXXX)
  printf '[%s]\n%s' "$capture_id" "$prompt" > "$prompt_file"

  local model_flag=""
  [[ -n "$model_id" ]] && model_flag="--model ${model_id}"

  tmux new-session -d -s "${session_id}" \
    -e "GREG_SESSION_ID=${session_id}" \
    "cd '${workspace}' && { printf '\\n'; cat '${prompt_file}'; } | claude ${CLAUDE_FLAGS} ${model_flag}; rm -f '${prompt_file}'"

  # Answer the trust prompt (reads from /dev/tty, not stdin — must use tmux send-keys)
  (sleep 8 && tmux send-keys -t "${session_id}" "" Enter 2>/dev/null) &

  # Capture claude_session_id by grepping for the unique capture_id in .jsonl files.
  # capture_id is only in this agent's prompt — not in manifest.json or any shared file.
  (
    sleep 15
    local encoded
    encoded=$(echo "${workspace}" | tr '/.' '-')
    local claude_dir="${HOME}/.claude/projects/${encoded}"
    local claude_sid
    claude_sid=$(grep -rl "${capture_id}" "${claude_dir}" 2>/dev/null \
      | grep '\.jsonl$' | head -1 | xargs basename 2>/dev/null | sed 's/\.jsonl$//')
    if [[ -n "$claude_sid" ]]; then
      local tmp; tmp=$(mktemp)
      jq "map(if .id == \"${session_id}\" then . + {claude_session_id: \"${claude_sid}\"} else . end)" \
        "${SESSIONS_FILE}" > "$tmp" && mv "$tmp" "${SESSIONS_FILE}"
    fi
  ) &

  sleep 2
}

_coordinator_loop() {
  local task_id="$1"
  local workspace="$2"
  shift 2
  local agent_ids=("$@")

  local status_dir="${workspace}/status"
  # Timeout: if a tmux session is dead and agent has output, treat as done after this many seconds
  local dead_session_timeout=120
  # Track first-dead timestamps as "aid:timestamp" entries in a plain string
  local first_dead_list=""

  echo "[$(date '+%H:%M:%S')] coordinator started (pid $$) — watching: ${agent_ids[*]}" \
    >> "${workspace}/coordinator.log"

  local all_done=false
  while [[ "$all_done" == false ]]; do
    sleep 15
    all_done=true

    local wmf="${workspace}/manifest.json"
    for aid in "${agent_ids[@]}"; do
      local sf="${status_dir}/${aid}.status"
      local agent_status=""
      [[ -f "$sf" ]] && agent_status=$(cat "$sf" 2>/dev/null | tr -d '[:space:]')

      if [[ "$agent_status" == "done" ]]; then
        continue
      fi

      # Not done — check if session is dead with output (crashed after finishing)
      local sid
      sid=$(jq -r --arg aid "$aid" '.agents[] | select(.id == $aid) | .session_id // empty' "$wmf" 2>/dev/null)
      local session_alive=false
      tmux has-session -t "$sid" 2>/dev/null && session_alive=true

      local output_file="${workspace}/workspace/${aid}.md"
      local has_output=false
      [[ -f "$output_file" && -s "$output_file" ]] && has_output=true

      if [[ "$session_alive" == false && "$has_output" == true ]]; then
        # Session dead but has output — start timeout countdown
        local now; now=$(date +%s)
        # Look up first_dead time for this aid in the plain string list
        local fd_time=""
        local fd_entry
        for fd_entry in $first_dead_list; do
          [[ "$fd_entry" == "${aid}:"* ]] && fd_time="${fd_entry#*:}" && break
        done
        if [[ -z "$fd_time" ]]; then
          first_dead_list="${first_dead_list} ${aid}:${now}"
          echo "[$(date '+%H:%M:%S')] ${aid}: session dead with output — starting ${dead_session_timeout}s timeout" \
            >> "${workspace}/coordinator.log"
        else
          local elapsed=$(( now - fd_time ))
          if [[ $elapsed -ge $dead_session_timeout ]]; then
            echo "[$(date '+%H:%M:%S')] ${aid}: timeout reached — forcing status to done" \
              >> "${workspace}/coordinator.log"
            echo "done" > "$sf"
            continue
          fi
        fi
      fi

      all_done=false
    done
  done

  echo "[$(date '+%H:%M:%S')] all agents done — marking completed, sessions stay alive" \
    >> "${workspace}/coordinator.log"

  # Mark task as completed — do NOT kill sessions; they remain available for follow-up
  local meta_file="${MULTI_TASKS_DIR}/${task_id}.json"
  local tmp; tmp=$(mktemp)
  jq --arg ts "$(_now)" '. + {coordinator_status: "completed", completed: $ts}' \
    "$meta_file" > "$tmp" && mv "$tmp" "$meta_file"

  echo "[$(date '+%H:%M:%S')] task ${task_id} complete — run 'greg task close ${task_id}' to end sessions" \
    >> "${workspace}/coordinator.log"
}

_short_id() {
  uuidgen | tr '[:upper:]' '[:lower:]' | cut -c1-8
}

_now() {
  date '+%Y-%m-%d %H:%M:%S'
}

_session_activity() {
  local sid="$1"
  tmux has-session -t "$sid" 2>/dev/null || { echo "finished"; return; }
  local pane
  pane=$(tmux capture-pane -t "$sid" -p 2>/dev/null | tail -15)
  if echo "$pane" | grep -qE 'Thinking|Symbioting|Crunching|⏺|↑ [0-9]+|↓ [0-9]+|· [0-9]+s'; then
    echo "running"
  else
    echo "active"
  fi
}

_current_session() {
  # Auto-detect session ID if inside a greg tmux session
  if [[ -n "${TMUX:-}" ]]; then
    local name
    name=$(tmux display-message -p '#S' 2>/dev/null || true)
    if [[ "$name" == greg-* ]]; then
      echo "$name"
      return
    fi
  fi
  echo ""
}

_claude_session_id_for_dir() {
  local dir="$1"
  # Claude encodes path: replaces both / and . with -
  local encoded
  encoded=$(echo "$dir" | tr '/.' '-')
  local claude_dir="${HOME}/.claude/projects/${encoded}"
  if [[ -d "$claude_dir" ]]; then
    # Most recently modified .jsonl file = last active session
    ls -t "${claude_dir}"/*.jsonl 2>/dev/null | head -1 | xargs basename 2>/dev/null | sed 's/\.jsonl$//' || true
  fi
}

_resolve_model() {
  local alias_or_id="$1"
  case "$alias_or_id" in
    opus)   echo "claude-opus-4-8" ;;
    sonnet) echo "claude-sonnet-4-6" ;;
    haiku)  echo "claude-haiku-4-5-20251001" ;;
    *)      echo "$alias_or_id" ;;
  esac
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_spawn() {
  local dir="${DEFAULT_DIR}"
  local name=""
  local prompt=""
  local model_id=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dir|-d)    dir="$2";                            shift 2 ;;
      --name|-n)   name="$2";                           shift 2 ;;
      --prompt|-p) prompt="$2";                         shift 2 ;;
      --model|-m)  model_id="$(_resolve_model "$2")";  shift 2 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local session_id="greg-$(_short_id)"
  [[ -z "$name" ]] && name="${session_id}"

  # Resolve dir
  dir="${dir/#\~/$HOME}"
  if [[ ! -d "$dir" ]]; then
    echo "Error: directory not found: $dir" >&2; exit 1
  fi

  # Register session
  local entry
  entry=$(jq -n \
    --arg id      "$session_id" \
    --arg name    "$name" \
    --arg dir     "$dir" \
    --arg started "$(_now)" \
    '{id:$id, name:$name, dir:$dir, started:$started, status:"active"}')
  local tmp; tmp=$(mktemp)
  jq ". += [$entry]" "${SESSIONS_FILE}" > "$tmp" && mv "$tmp" "${SESSIONS_FILE}"

  local model_flag=""
  [[ -n "$model_id" ]] && model_flag="--model ${model_id}"

  # Start tmux session with GREG_SESSION_ID injected
  tmux new-session -d -s "${session_id}" \
    -e "GREG_SESSION_ID=${session_id}" \
    "cd '${dir}' && claude ${CLAUDE_FLAGS} ${model_flag}"

  # Inject initial prompt after claude loads
  if [[ -n "$prompt" ]]; then
    sleep 1.5
    tmux send-keys -t "${session_id}" "$prompt" Enter
  fi

  echo "started  ${session_id} (${name})"
  echo "dir      ${dir}"
  echo "attach   greg attach ${session_id}"
}

cmd_list() {
  # Collect session IDs from workspace manifests (meta file doesn't have them)
  local task_session_ids=""
  for meta in "${MULTI_TASKS_DIR}"/*.json; do
    [[ -f "$meta" ]] || continue
    local ws; ws=$(jq -r '.workspace' "$meta")
    local wmf="${ws}/manifest.json"
    [[ -f "$wmf" ]] || continue
    while IFS= read -r sid; do
      task_session_ids="${task_session_ids} ${sid}"
    done < <(jq -r '.agents[].session_id // empty' "$wmf")
  done

  echo "Multi-agent tasks:"
  local found_tasks=false
  for meta in "${MULTI_TASKS_DIR}"/*.json; do
    [[ -f "$meta" ]] || continue
    found_tasks=true
    local tid goal cstatus workspace
    tid=$(jq -r '.task_id' "$meta")
    goal=$(jq -r '.goal' "$meta")
    cstatus=$(jq -r '.coordinator_status' "$meta")
    workspace=$(jq -r '.workspace' "$meta")
    local wmf="${workspace}/manifest.json"
    printf "  %-22s [%-14s] %s\n" "$tid" "$cstatus" "${goal:0:55}"
    while IFS=$'\t' read -r aid sid; do
      local sf="${workspace}/status/${aid}.status"
      local astatus="(not started)"
      [[ -f "$sf" ]] && astatus=$(cat "$sf" | tr -d '[:space:]')
      local tmux_flag=""
      tmux has-session -t "$sid" 2>/dev/null && tmux_flag="▶" || tmux_flag="■"
      printf "    ├ %-14s %s %-20s [%s]\n" "$aid" "$tmux_flag" "$sid" "$astatus"
    done < <(jq -r '.agents[] | [.id, (.session_id // "?")] | @tsv' "$wmf" 2>/dev/null)
  done
  [[ "$found_tasks" == false ]] && echo "  (none)"

  echo ""
  echo "Standalone sessions:"
  local found_sessions=false
  if jq -e 'length > 0' "${SESSIONS_FILE}" > /dev/null 2>&1; then
    while IFS=$'\t' read -r sid sname sstarted; do
      [[ " ${task_session_ids} " == *" ${sid} "* ]] && continue
      found_sessions=true
      local astatus
      astatus=$(_session_activity "$sid")
      printf "  %-22s [%-8s] %-20s %s\n" "$sid" "$astatus" "$sname" "$sstarted"
    done < <(jq -r '.[] | [.id, .name, .started] | @tsv' "${SESSIONS_FILE}")
  fi
  [[ "$found_sessions" == false ]] && echo "  (none)"

  echo ""
  echo "Scheduled tasks:"
  if jq -e 'length > 0' "${TASKS_FILE}" > /dev/null 2>&1; then
    jq -r '.[] | "  \(.id)  at \(.at)  \(.prompt | .[0:60])"' "${TASKS_FILE}"
  else
    echo "  (none)"
  fi

  echo ""
  echo "Recent history (last 3):"
  if jq -e 'length > 0' "${HISTORY_FILE}" > /dev/null 2>&1; then
    jq -r 'reverse | .[0:3][] | "  \(.id)  [finished]  \(.name)  \(.ended)"' "${HISTORY_FILE}"
  else
    echo "  (none)"
  fi
}

cmd_attach() {
  local id="${1:-}"

  if [[ -z "$id" ]]; then
    local -a ids labels
    while IFS=$'\t' read -r sid sname; do
      ids+=("$sid")
      labels+=("$sid  ($sname)")
    done < <(jq -r '.[] | [.id, .name] | @tsv' "${SESSIONS_FILE}" 2>/dev/null)

    if [[ ${#ids[@]} -eq 0 ]]; then
      echo "No active sessions." >&2; exit 1
    fi

    PS3="session: "
    select choice in "${labels[@]}"; do
      [[ -n "$choice" ]] && { id="${ids[$((REPLY - 1))]}"; break; }
    done
    [[ -z "$id" ]] && exit 0
  fi

  tmux attach -t "$id"
}

cmd_send_msg() {
  local from=""
  local to=""
  local workspace=""
  local message=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from|-f)      from="$2";      shift 2 ;;
      --to|-t)        to="$2";        shift 2 ;;
      --workspace|-w) workspace="$2"; shift 2 ;;
      *)              message="$1";   shift   ;;
    esac
  done

  [[ -z "$from" || -z "$to" || -z "$workspace" || -z "$message" ]] && {
    echo "Usage: greg send-msg --from <id> --to <id> --workspace <path> \"<message>\"" >&2; exit 1
  }

  local messages_dir="${workspace}/messages"
  mkdir -p "$messages_dir"
  local msg_file="${messages_dir}/${from}→${to}.md"

  printf '\n### [%s] %s → %s\n%s\n' "$(date '+%H:%M:%S')" "$from" "$to" "$message" >> "$msg_file"
  echo "sent → ${to}"
}

cmd_kill() {
  local id="${1:-}"
  [[ -z "$id" ]] && { echo "Usage: greg kill <session-id>" >&2; exit 1; }

  # Find session entry before removing it
  local entry
  entry=$(jq -r "map(select(.id == \"${id}\")) | .[0]" "${SESSIONS_FILE}")
  if [[ "$entry" == "null" || -z "$entry" ]]; then
    echo "Session not found: $id" >&2; exit 1
  fi

  # Use claude_session_id captured at runtime — never fall back to dir scan,
  # that picks the most recently touched .jsonl and assigns it to the wrong session.
  local claude_sid=""
  claude_sid=$(echo "$entry" | jq -r '.claude_session_id // empty')

  # Archive to history
  local archived
  if [[ -n "$claude_sid" ]]; then
    archived=$(echo "$entry" | jq \
      --arg ended      "$(_now)" \
      --arg claude_sid "$claude_sid" \
      '. + {status:"finished", ended:$ended, claude_session_id:$claude_sid}')
  else
    archived=$(echo "$entry" | jq \
      --arg ended "$(_now)" \
      '. + {status:"finished", ended:$ended}')
  fi
  local tmp; tmp=$(mktemp)
  jq ". += [$archived]" "${HISTORY_FILE}" > "$tmp" && mv "$tmp" "${HISTORY_FILE}"

  tmux kill-session -t "$id" 2>/dev/null || true

  tmp=$(mktemp)
  jq "map(select(.id != \"${id}\"))" "${SESSIONS_FILE}" > "$tmp" && mv "$tmp" "${SESSIONS_FILE}"

  echo "killed ${id}"
  if [[ -n "$claude_sid" ]]; then
    echo "archived  claude_session_id=${claude_sid}"
  else
    echo "archived  (sin claude_session_id — sesión sin mensajes)"
  fi
}

cmd_start() {
  cmd_spawn "$@"
  local session_id
  session_id=$(jq -r '.[-1].id' "${SESSIONS_FILE}")
  tmux attach -t "${session_id}"
}

cmd_history() {
  local limit=10
  [[ "${1:-}" == "--limit" ]] && { limit="$2"; shift 2; }

  if jq -e 'length > 0' "${HISTORY_FILE}" > /dev/null 2>&1; then
    echo "Last ${limit} sessions:"
    jq -r "reverse | .[0:${limit}][] |
      \"  \(.id)  \(.name)  [\(.status)]  \(.started) → \(.ended)  claude:\(.claude_session_id // \"unknown\")\"" \
      "${HISTORY_FILE}"
  else
    echo "  (no history)"
  fi
}

cmd_resume() {
  local id="${1:-}"
  [[ -z "$id" ]] && { echo "Usage: greg resume <session-id>" >&2; exit 1; }

  local entry
  entry=$(jq -r "map(select(.id == \"${id}\")) | .[0]" "${HISTORY_FILE}")
  if [[ "$entry" == "null" || -z "$entry" ]]; then
    echo "Session not found in history: $id" >&2; exit 1
  fi

  local claude_sid dir name
  claude_sid=$(echo "$entry" | jq -r '.claude_session_id // empty')
  dir=$(echo "$entry" | jq -r '.dir')
  name=$(echo "$entry" | jq -r '.name')

  [[ -z "$claude_sid" ]] && {
    echo "No claude_session_id stored for ${id} — cannot resume" >&2; exit 1
  }

  local new_id="greg-$(_short_id)"

  # Escribir claude_session_id inmediatamente — lo conocemos, no hay que capturarlo después.
  local new_entry
  new_entry=$(jq -n \
    --arg id           "$new_id" \
    --arg name         "$name" \
    --arg dir          "$dir" \
    --arg started      "$(_now)" \
    --arg claude_sid   "$claude_sid" \
    --arg resumed_from "$id" \
    '{id:$id, name:$name, dir:$dir, started:$started, status:"active", claude_session_id:$claude_sid, resumed_from:$resumed_from}')
  local tmp; tmp=$(mktemp)
  jq ". += [$new_entry]" "${SESSIONS_FILE}" > "$tmp" && mv "$tmp" "${SESSIONS_FILE}"

  tmux new-session -d -s "${new_id}" \
    -e "GREG_SESSION_ID=${new_id}" \
    "cd '${dir}' && claude ${CLAUDE_FLAGS} --resume '${claude_sid}'"

  echo "resumed  ${new_id} (from ${id})"
  echo "claude   ${claude_sid}"
  echo "attach   greg attach ${new_id}"
}

cmd_schedule() {
  local prompt=""
  local at=""
  local dir="${DEFAULT_DIR}"
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --prompt|-p) prompt="$2"; shift 2 ;;
      --at)        at="$2";     shift 2 ;;
      --dir|-d)    dir="$2";    shift 2 ;;
      --name|-n)   name="$2";   shift 2 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  [[ -z "$prompt" || -z "$at" ]] && {
    echo "Usage: greg schedule --prompt \"...\" --at \"YYYY-MM-DD HH:MM\" [--dir <path>] [--name <n>]" >&2
    exit 1
  }

  local task_id="task-$(_short_id)"
  [[ -z "$name" ]] && name="${task_id}"

  # Parse datetime → cron fields (minute hour day month *)
  local minute hour day month
  minute=$(date -j -f '%Y-%m-%d %H:%M' "$at" '+%M' 2>/dev/null) || {
    echo "Error: invalid date format. Use YYYY-MM-DD HH:MM" >&2; exit 1
  }
  hour=$(date  -j -f '%Y-%m-%d %H:%M' "$at" '+%H')
  day=$(date   -j -f '%Y-%m-%d %H:%M' "$at" '+%d')
  month=$(date -j -f '%Y-%m-%d %H:%M' "$at" '+%m')

  # Write one-shot runner script
  local runner="${GREG_HOME}/${task_id}.sh"
  cat > "$runner" << RUNNER
#!/usr/bin/env bash
# One-shot greg task: ${task_id}
"${GREG_BIN}" spawn --dir '${dir}' --name '${name}' --prompt '${prompt}'

# Self-remove from crontab
crontab -l 2>/dev/null | grep -v "${task_id}" | crontab -
rm -f "${runner}"
RUNNER
  chmod +x "$runner"

  # Add to crontab
  (crontab -l 2>/dev/null; echo "${minute} ${hour} ${day} ${month} * '${runner}' # ${task_id}") | crontab -

  # Register task
  local entry
  entry=$(jq -n \
    --arg id     "$task_id" \
    --arg name   "$name" \
    --arg prompt "$prompt" \
    --arg at     "$at" \
    --arg dir    "$dir" \
    '{id:$id, name:$name, prompt:$prompt, at:$at, dir:$dir}')
  local tmp; tmp=$(mktemp)
  jq ". += [$entry]" "${TASKS_FILE}" > "$tmp" && mv "$tmp" "${TASKS_FILE}"

  echo "scheduled  ${task_id} (${name})"
  echo "at         ${at}"
  echo "cron       ${minute} ${hour} ${day} ${month} *"
}

cmd_cancel() {
  local id="${1:-}"
  [[ -z "$id" ]] && { echo "Usage: greg cancel <task-id>" >&2; exit 1; }

  crontab -l 2>/dev/null | grep -v "$id" | crontab - 2>/dev/null || true
  rm -f "${GREG_HOME}/${id}.sh"

  local tmp; tmp=$(mktemp)
  jq "map(select(.id != \"${id}\"))" "${TASKS_FILE}" > "$tmp" && mv "$tmp" "${TASKS_FILE}"

  echo "cancelled ${id}"
}

cmd_task() {
  local subcmd="${1:-help}"
  shift || true

  case "$subcmd" in
    run)     _task_run     "$@" ;;
    status)  _task_status  "$@" ;;
    list)    _task_list ;;
    done)    _task_done    "$@" ;;
    close)   _task_close   "$@" ;;
    message) _task_message "$@" ;;
    resume)  _task_resume  "$@" ;;
    *)
      cat << 'EOF'
greg task — multi-agent task runner

  task run --goal "..." --agent "id:role description" [--agent ...]
           Launch a multi-agent task.
           Agent format: "<id>:<role description>"

  task status <task-id>                  Show current agent statuses
  task list                              List all multi-agent tasks
  task done <task-id> <agent-id>         Mark a specific agent as done
  task close <task-id>                   Mark task as completed (requires all agents done)
  task message <task-id> "<message>"     Send a message to the director
  task resume <task-id> <agent-id>       Resume a finished agent session
EOF
    ;;
  esac
}

_task_run() {
  local goal=""
  local dir="${DEFAULT_DIR}"
  local preset=""
  local model_id=""
  local -a agent_specs=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --goal|-g)  goal="$2";                            shift 2 ;;
      --agent|-a) agent_specs+=("$2");                  shift 2 ;;
      --dir|-d)   dir="$2";                             shift 2 ;;
      --preset)   preset="$2";                          shift 2 ;;
      --model|-m) model_id="$(_resolve_model "$2")";   shift 2 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  [[ -z "$goal" ]] && { echo "Error: --goal is required" >&2; exit 1; }
  [[ ${#agent_specs[@]} -lt 1 ]] && { echo "Error: at least one --agent is required" >&2; exit 1; }

  dir="${dir/#\~/$HOME}"
  [[ ! -d "$dir" ]] && { echo "Error: directory not found: $dir" >&2; exit 1; }

  if [[ -n "$preset" && "$preset" != "coding" && "$preset" != "research" ]]; then
    echo "Error: unknown preset '$preset'. Valid values: coding, research" >&2; exit 1
  fi

  local task_id="mtask-$(_short_id)"
  local workspace="${MULTI_TASKS_DIR}/${task_id}"
  mkdir -p "${workspace}/workspace" "${workspace}/messages" "${workspace}/status"

  # ── PRESET coding: crear worktree git aislado ────────────────────────────────
  local agent_spawn_dir="$workspace"
  if [[ "$preset" == "coding" ]]; then
    local worktree_path="/tmp/greg-worktree-${task_id}"
    if git -C "$dir" rev-parse --is-inside-work-tree > /dev/null 2>&1; then
      git -C "$dir" worktree add "$worktree_path" HEAD
      agent_spawn_dir="$worktree_path"
      echo "worktree ${worktree_path}"
    else
      echo "Warning: --preset coding: '$dir' no es un repo git — continuando sin worktree" >&2
    fi
  fi

  # Build agent list: always prepend director
  local -a all_agents=("director:Coordinate the team, monitor progress, facilitate cross-pollination between specialists, and ensure the final output is coherent")
  for spec in "${agent_specs[@]}"; do
    all_agents+=("$spec")
  done

  # Write manifest.json
  local agents_json="[]"
  for spec in "${all_agents[@]}"; do
    local aid="${spec%%:*}"
    local arole="${spec#*:}"
    agents_json=$(echo "$agents_json" | jq \
      --arg id "$aid" --arg role "$arole" \
      '. += [{id: $id, role: $role}]')
  done

  jq -n \
    --arg task_id  "$task_id" \
    --arg goal     "$goal" \
    --arg workspace "$workspace" \
    --arg created  "$(_now)" \
    --arg preset   "$preset" \
    --argjson agents "$agents_json" \
    '{task_id: $task_id, goal: $goal, workspace: $workspace, created: $created, agents: $agents, preset: $preset}' \
    > "${workspace}/manifest.json"

  # Save multi-task metadata
  jq -n \
    --arg task_id   "$task_id" \
    --arg goal      "$goal" \
    --arg workspace "$workspace" \
    --arg created   "$(_now)" \
    --arg preset    "$preset" \
    --argjson agents "$agents_json" \
    '{task_id: $task_id, goal: $goal, workspace: $workspace, created: $created, agents: $agents, preset: $preset, coordinator_status: "running", schema_version: 2}' \
    > "${MULTI_TASKS_DIR}/${task_id}.json"

  echo "task     ${task_id}"
  echo "goal     ${goal}"
  echo "workspace ${workspace}"
  echo ""

  local -a spawned_ids=()

  # Spawn each agent
  for spec in "${all_agents[@]}"; do
    local aid="${spec%%:*}"
    local arole="${spec#*:}"
    local session_id="greg-$(_short_id)"
    spawned_ids+=("$aid")

    # Resolve skill template
    local skill_file
    if [[ "$aid" == "director" ]]; then
      skill_file="${SKILLS_DIR}/agents/director.md"
    else
      skill_file="${SKILLS_DIR}/agents/teammate.md"
    fi

    # ── PRESET: inyección de instrucciones en el rol del agente ───────────────
    local effective_role="$arole"
    _inject_preset_skill() {
      local skill_file="$1"
      local agent_id="$2"
      if [[ -f "$skill_file" ]]; then
        local skill_content
        skill_content=$(sed "s/{{AGENT_ID}}/${agent_id}/g" "$skill_file")
        echo "$skill_content"
      fi
    }
    if [[ "$preset" == "coding" && "$aid" != "director" ]]; then
      local coding_skill="${SKILLS_DIR}/coding/workflow/SKILL.md"
      local coding_content
      coding_content=$(_inject_preset_skill "$coding_skill" "$aid")
      [[ -n "$coding_content" ]] && effective_role="${effective_role}"$'\n\n'"${coding_content}"
    elif [[ "$preset" == "research" && "$aid" != "director" ]]; then
      if echo "$effective_role" | grep -qiE 'recolect|gather|search|busca'; then
        local collector_skill="${SKILLS_DIR}/research/collector/SKILL.md"
        local collector_content
        collector_content=$(_inject_preset_skill "$collector_skill" "$aid")
        [[ -n "$collector_content" ]] && effective_role="${effective_role}"$'\n\n'"${collector_content}"
      elif echo "$effective_role" | grep -qiE 'analiz|review|critic|evalúa|sintetiz'; then
        local analyzer_skill="${SKILLS_DIR}/research/analyzer/SKILL.md"
        local analyzer_content
        analyzer_content=$(_inject_preset_skill "$analyzer_skill" "$aid")
        [[ -n "$analyzer_content" ]] && effective_role="${effective_role}"$'\n\n'"${analyzer_content}"
      fi
    fi

    local prompt
    prompt=$(_resolve_skill "$skill_file" "$task_id" "$aid" "$effective_role" "$goal" "$workspace" "$session_id")

    # Map agent id → session id in manifest
    local tmp; tmp=$(mktemp)
    jq --arg aid "$aid" --arg sid "$session_id" \
      '.agents = [.agents[] | if .id == $aid then . + {session_id: $sid} else . end]' \
      "${workspace}/manifest.json" > "$tmp" && mv "$tmp" "${workspace}/manifest.json"

    _spawn_agent "$session_id" "${aid}-${task_id}" "$agent_spawn_dir" "$prompt" "$model_id"
    echo "spawned  ${aid} → ${session_id}"
  done

  echo ""

  # Start background coordinator — nohup so it survives terminal closure
  nohup "${GREG_BIN}" _coordinator "${task_id}" "${workspace}" "${spawned_ids[@]}" \
    >> "${workspace}/coordinator.log" 2>&1 &
  local coord_pid=$!
  disown "$coord_pid"
  echo "$coord_pid" > "${workspace}/coordinator.pid"

  echo "coordinator started (pid ${coord_pid})"
  echo "monitor  greg task status ${task_id}"
}

_task_status() {
  local task_id="${1:-}"
  [[ -z "$task_id" ]] && { echo "Usage: greg task status <task-id>" >&2; exit 1; }

  local meta_file="${MULTI_TASKS_DIR}/${task_id}.json"
  [[ ! -f "$meta_file" ]] && { echo "Task not found: $task_id" >&2; exit 1; }

  local goal workspace coordinator_status
  goal=$(jq -r '.goal' "$meta_file")
  workspace=$(jq -r '.workspace' "$meta_file")
  coordinator_status=$(jq -r '.coordinator_status' "$meta_file")

  # Check if coordinator is alive
  local coord_alive="stopped"
  local pid_file="${workspace}/coordinator.pid"
  if [[ -f "$pid_file" ]]; then
    local cpid; cpid=$(cat "$pid_file")
    kill -0 "$cpid" 2>/dev/null && coord_alive="running (pid ${cpid})"
  fi

  echo "task        ${task_id}"
  echo "goal        ${goal}"
  echo "status      ${coordinator_status}"
  echo "coordinator ${coord_alive}"
  echo ""
  echo "Agents:"

  local wmf="${workspace}/manifest.json"
  while IFS=$'\t' read -r aid arole sid; do
    local status_file="${workspace}/status/${aid}.status"
    local agent_status="(not started)"
    [[ -f "$status_file" ]] && agent_status=$(cat "$status_file" | tr -d '[:space:]')
    local tmux_status=""
    tmux has-session -t "$sid" 2>/dev/null && tmux_status=" (tmux: running)" || tmux_status=" (tmux: stopped)"
    printf "  %-16s %-12s %-20s %s\n" "$aid" "[$agent_status]" "${sid}${tmux_status}" "$arole"
  done < <(jq -r '.agents[] | [.id, .role, (.session_id // "?")] | @tsv' "$wmf" 2>/dev/null)

  # Show final output if exists
  local final="${workspace}/final-output.md"
  if [[ -f "$final" ]]; then
    echo ""
    echo "Final output: ${final}"
  fi
}

_task_done() {
  local task_id="${1:-}"
  local agent_id="${2:-}"
  [[ -z "$task_id" || -z "$agent_id" ]] && {
    echo "Usage: greg task done <task-id> <agent-id>" >&2; exit 1
  }

  local meta_file="${MULTI_TASKS_DIR}/${task_id}.json"
  [[ ! -f "$meta_file" ]] && { echo "Task not found: $task_id" >&2; exit 1; }

  local workspace
  workspace=$(jq -r '.workspace' "$meta_file")
  local wmf="${workspace}/manifest.json"

  # Verify the agent-id belongs to this task
  local is_agent
  is_agent=$(jq -r --arg aid "$agent_id" '.agents[] | select(.id == $aid) | .id' "$wmf" 2>/dev/null)

  if [[ -z "$is_agent" ]]; then
    echo "Agent not found: $agent_id in task $task_id" >&2; exit 1
  fi

  # Write done status
  local sf="${workspace}/status/${agent_id}.status"
  mkdir -p "$(dirname "$sf")"
  echo "done" > "$sf"
  echo "marked ${agent_id} as done"

  # Kill tmux session if alive
  local sid
  sid=$(jq -r --arg aid "$agent_id" '.agents[] | select(.id == $aid) | .session_id // empty' "$wmf" 2>/dev/null)
  [[ -z "$sid" ]] && sid="$agent_id"
  tmux kill-session -t "$sid" 2>/dev/null && echo "killed session ${sid}" || true
}

_task_close() {
  local task_id="${1:-}"
  [[ -z "$task_id" ]] && { echo "Usage: greg task close <task-id>" >&2; exit 1; }

  local meta_file="${MULTI_TASKS_DIR}/${task_id}.json"
  [[ ! -f "$meta_file" ]] && { echo "Task not found: $task_id" >&2; exit 1; }

  local workspace
  workspace=$(jq -r '.workspace' "$meta_file")
  local wmf="${workspace}/manifest.json"

  # Verify all agents are done
  local not_done=()
  while IFS= read -r aid; do
    local sf="${workspace}/status/${aid}.status"
    local s=""
    [[ -f "$sf" ]] && s=$(cat "$sf" | tr -d '[:space:]')
    [[ "$s" != "done" ]] && not_done+=("$aid")
  done < <(jq -r '.agents[].id' "$wmf" 2>/dev/null)

  if [[ ${#not_done[@]} -gt 0 ]]; then
    echo "Cannot close: agents not done: ${not_done[*]}" >&2; exit 1
  fi

  # Kill stale coordinator
  local pid_file="${workspace}/coordinator.pid"
  if [[ -f "$pid_file" ]]; then
    local old_pid; old_pid=$(cat "$pid_file")
    kill "$old_pid" 2>/dev/null && echo "killed coordinator (pid ${old_pid})" || true
    rm -f "$pid_file"
  fi

  # Mark task as completed
  local tmp; tmp=$(mktemp)
  jq --arg ts "$(_now)" '. + {coordinator_status: "completed", completed: $ts}' \
    "$meta_file" > "$tmp" && mv "$tmp" "$meta_file"

  echo "task ${task_id} closed as completed"
}

_task_message() {
  local task_id="${1:-}"
  local message="${2:-}"
  [[ -z "$task_id" || -z "$message" ]] && {
    echo "Usage: greg task message <task-id> \"<message>\"" >&2; exit 1
  }

  local meta_file="${MULTI_TASKS_DIR}/${task_id}.json"
  [[ ! -f "$meta_file" ]] && { echo "Task not found: $task_id" >&2; exit 1; }

  local workspace
  workspace=$(jq -r '.workspace' "$meta_file")

  cmd_send_msg --from "human" --to "director" --workspace "$workspace" "$message"

  # Notify director via tmux if session is alive (human→director is the only case that still needs this,
  # since the human is not a greg agent and can't use wait-msg)
  local wmf="${workspace}/manifest.json"
  local director_sid
  director_sid=$(jq -r '.agents[] | select(.id == "director") | .session_id // empty' "$wmf" 2>/dev/null)

  if [[ -n "$director_sid" ]] && tmux has-session -t "$director_sid" 2>/dev/null; then
    tmux send-keys -t "$director_sid" "[HUMAN MESSAGE] Check messages/human→director.md" Enter 2>/dev/null
    echo "delivered → director (${director_sid})"
  else
    echo "queued → director inbox (session not active)"
  fi
  echo "message: ${message}"
}

_task_resume() {
  local task_id="${1:-}"
  local agent_id="${2:-}"
  [[ -z "$task_id" || -z "$agent_id" ]] && {
    echo "Usage: greg task resume <task-id> <agent-id>" >&2; exit 1
  }

  local meta_file="${MULTI_TASKS_DIR}/${task_id}.json"
  [[ ! -f "$meta_file" ]] && { echo "Task not found: $task_id" >&2; exit 1; }

  local workspace
  workspace=$(jq -r '.workspace' "$meta_file")
  local wmf="${workspace}/manifest.json"

  # Get greg session ID for this agent
  local agent_greg_sid
  agent_greg_sid=$(jq -r --arg aid "$agent_id" '.agents[] | select(.id == $aid) | .session_id // empty' "$wmf" 2>/dev/null)
  [[ -z "$agent_greg_sid" ]] && { echo "Agent not found: $agent_id" >&2; exit 1; }

  # Find claude_session_id in sessions.json then history.json
  local claude_sid
  claude_sid=$(jq -r --arg sid "$agent_greg_sid" \
    '.[] | select(.id == $sid) | .claude_session_id // empty' "${SESSIONS_FILE}" 2>/dev/null)
  [[ -z "$claude_sid" || "$claude_sid" == "null" ]] && \
    claude_sid=$(jq -r --arg sid "$agent_greg_sid" \
      '.[] | select(.id == $sid) | .claude_session_id // empty' "${HISTORY_FILE}" 2>/dev/null)

  [[ -z "$claude_sid" || "$claude_sid" == "null" ]] && {
    echo "No claude_session_id found for ${agent_id} (${agent_greg_sid})" >&2
    echo "Run 'greg task status ${task_id}' to verify session IDs." >&2
    exit 1
  }

  local new_id="greg-$(_short_id)"

  local new_entry
  new_entry=$(jq -n \
    --arg id      "$new_id" \
    --arg name    "${agent_id}-${task_id}" \
    --arg dir     "$workspace" \
    --arg started "$(_now)" \
    '{id:$id, name:$name, dir:$dir, started:$started, status:"active"}')
  local tmp; tmp=$(mktemp)
  jq ". += [$new_entry]" "${SESSIONS_FILE}" > "$tmp" && mv "$tmp" "${SESSIONS_FILE}"

  tmux new-session -d -s "${new_id}" \
    -e "GREG_SESSION_ID=${new_id}" \
    "cd '${workspace}' && claude ${CLAUDE_FLAGS} --resume '${claude_sid}'"

  (sleep 8 && tmux send-keys -t "${new_id}" "" Enter 2>/dev/null) &

  echo "resumed  ${new_id}"
  echo "agent    ${agent_id} (${agent_greg_sid})"
  echo "claude   ${claude_sid}"
  echo "attach   greg attach ${new_id}"
}

_task_list() {
  local found=false
  for f in "${MULTI_TASKS_DIR}"/*.json; do
    [[ -f "$f" ]] || continue
    found=true
    local task_id goal created coordinator_status
    task_id=$(jq -r '.task_id' "$f")
    goal=$(jq -r '.goal' "$f")
    created=$(jq -r '.created' "$f")
    coordinator_status=$(jq -r '.coordinator_status' "$f")
    printf "  %-20s [%-14s] %s  %s\n" "$task_id" "$coordinator_status" "$created" "${goal:0:60}"
  done
  [[ "$found" == false ]] && echo "  (no multi-agent tasks)"
}

cmd_wait_msg() {
  local agent_id=""
  local workspace=""
  local timeout=300

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agent|-a)     agent_id="$2";   shift 2 ;;
      --workspace|-w) workspace="$2";  shift 2 ;;
      --timeout|-t)   timeout="$2";    shift 2 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  [[ -z "$agent_id" || -z "$workspace" ]] && {
    echo "Usage: greg wait-msg --agent <id> --workspace <path> [--timeout <secs>]" >&2; exit 1
  }

  local messages_dir="${workspace}/messages"
  mkdir -p "$messages_dir"

  echo "waiting for message → ${agent_id} (timeout: ${timeout}s)"

  if command -v fswatch > /dev/null 2>&1; then
    ( fswatch "$messages_dir" 2>/dev/null | grep -m 1 "→${agent_id}\.md" > /dev/null ) &
    local bg_pid=$!
    ( sleep "$timeout" && kill "$bg_pid" 2>/dev/null ) &
    local kill_pid=$!
    wait "$bg_pid" 2>/dev/null
    local exit_code=$?
    kill "$kill_pid" 2>/dev/null
    wait "$kill_pid" 2>/dev/null
    if [[ $exit_code -ne 0 ]]; then
      echo "timeout: no message received in ${timeout}s" >&2; exit 1
    fi
  else
    # Fallback: poll every 2 seconds
    local marker="${workspace}/.msg-read-${agent_id}"
    [[ ! -f "$marker" ]] && touch "$marker"
    local start; start=$(date +%s)
    while true; do
      local new
      new=$(find "$messages_dir" -name "*→${agent_id}.md" -newer "$marker" 2>/dev/null | head -1)
      [[ -n "$new" ]] && break
      local now; now=$(date +%s)
      if [[ $(( now - start )) -ge $timeout ]]; then
        echo "timeout: no message received in ${timeout}s" >&2; exit 1
      fi
      sleep 2
    done
  fi

  echo "message received"
  cmd_check_msgs --agent "$agent_id" --workspace "$workspace"
}

cmd_check_msgs() {
  local agent_id=""
  local workspace=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agent|-a)     agent_id="$2";   shift 2 ;;
      --workspace|-w) workspace="$2";  shift 2 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  [[ -z "$agent_id" || -z "$workspace" ]] && {
    echo "Usage: greg check-msgs --agent <id> --workspace <path>" >&2; exit 1
  }

  local messages_dir="${workspace}/messages"
  local marker="${workspace}/.msg-read-${agent_id}"

  [[ ! -f "$marker" ]] && touch "$marker"

  local found=false
  while IFS= read -r msg_file; do
    found=true
    local sender
    sender=$(basename "$msg_file" | sed "s/→${agent_id}\\.md$//")
    echo "=== [$(date '+%H:%M:%S')] message from ${sender} ==="
    cat "$msg_file"
    echo ""
  done < <(find "$messages_dir" -name "*→${agent_id}.md" -newer "$marker" 2>/dev/null | sort)

  [[ "$found" == true ]] && touch "$marker" || echo "(no new messages for ${agent_id})"
}

cmd_peek() {
  local target="${1:-}"
  local lines=30

  [[ -z "$target" ]] && { echo "Usage: greg peek <session-id|task-id> [-n lines]" >&2; exit 1; }
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n) lines="$2"; shift 2 ;;
      *)  echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  # If it's a task ID, peek all agents
  if [[ "$target" == mtask-* ]]; then
    local meta_file="${MULTI_TASKS_DIR}/${target}.json"
    [[ ! -f "$meta_file" ]] && { echo "Task not found: $target" >&2; exit 1; }

    local workspace
    workspace=$(jq -r '.workspace' "$meta_file")
    local wmf="${workspace}/manifest.json"

    while IFS=$'\t' read -r aid sid; do
      echo "━━━ ${aid} (${sid}) ━━━"
      if tmux has-session -t "$sid" 2>/dev/null; then
        tmux capture-pane -t "$sid" -p 2>/dev/null \
          | sed 's/\x1b\[[0-9;]*[a-zA-Z]//g; s/\x1b\][^\x07]*\x07//g; s/\x0f//g' \
          | tail -"$lines"
      else
        echo "(session not running)"
      fi
      echo ""
    done < <(jq -r '.agents[] | [.id, (.session_id // "?")] | @tsv' "$wmf" 2>/dev/null)
    return
  fi

  # Single session
  if ! tmux has-session -t "$target" 2>/dev/null; then
    echo "Session not running: $target" >&2; exit 1
  fi

  tmux capture-pane -t "$target" -p 2>/dev/null \
    | sed 's/\x1b\[[0-9;]*[a-zA-Z]//g; s/\x1b\][^\x07]*\x07//g; s/\x0f//g' \
    | tail -"$lines"
}

cmd_help() {
  cat << 'EOF'
greg — multi-agent Claude Code manager

  start    [--name <n>] [--dir <path>] [--prompt <p>] [--model <alias|id>]   start instance & attach immediately
  spawn    [--name <n>] [--dir <path>] [--prompt <p>] [--model <alias|id>]   start instance in background
  resume   <session-id>                                     resume a past session
  schedule --prompt <p> --at "YYYY-MM-DD HH:MM"           schedule one-shot task
             [--dir <path>] [--name <n>]
  list                                                      show sessions, tasks & recent history
  history  [--limit N]                                      show last N finished sessions (default 10)
  attach   <session-id>                                     tmux attach
  peek     <session-id|task-id> [-n lines]                  show last N lines from tmux pane (default 30)
  kill     <session-id>                                     stop & archive session
  cancel   <task-id>                                        cancel scheduled task

  wait-msg   --agent <id> --workspace <path> [--timeout <secs>]   block until a message arrives (uses fswatch)
  check-msgs --agent <id> --workspace <path>               print and mark new messages as read

  task run --goal "..." --agent "id:role" [--agent ...]   launch multi-agent task
           [--preset coding|research] [--model <alias|id>]
  task status <task-id>                                    show agent statuses
  task list                                                list all multi-agent tasks
  task done <task-id> <agent-id>                           mark agent as done
  task close <task-id>                                     close task (requires all agents done)
  task message <task-id> "<msg>"                           send message to director
  task resume <task-id> <agent-id>                         resume a finished agent

Model aliases: opus→claude-opus-4-8  sonnet→claude-sonnet-4-6  haiku→claude-haiku-4-5-20251001
Default dir: $GREG_VAULT (or $HOME if not set)
EOF
}

# ── Main ──────────────────────────────────────────────────────────────────────

_init

case "${1:-help}" in
  start)    shift; cmd_start    "$@" ;;
  spawn)    shift; cmd_spawn    "$@" ;;
  resume)   shift; cmd_resume   "$@" ;;
  schedule) shift; cmd_schedule "$@" ;;
  history)  shift; cmd_history  "$@" ;;
  list)     cmd_list ;;
  attach)   shift; cmd_attach   "$@" ;;
  peek)     shift; cmd_peek     "$@" ;;
  kill)     shift; cmd_kill     "$@" ;;
  cancel)   shift; cmd_cancel   "$@" ;;
  task)       shift; cmd_task      "$@" ;;
  wait-msg)   shift; cmd_wait_msg  "$@" ;;
  check-msgs) shift; cmd_check_msgs "$@" ;;
  _coordinator) shift; _coordinator_loop "$@" ;;
  help|--help|-h) cmd_help ;;
  *) echo "Unknown command: $1. Run 'greg help'" >&2; exit 1 ;;
esac
